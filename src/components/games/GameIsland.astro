---
import Pong from "./Pong.astro";
import BlockBreaker from "./BlockBreaker.astro";
import Racing3D from "./Racing3D.astro";
---

<!-- Game Island -->
<div id="games" class="pointer-events-auto max-w-4xl mx-auto w-full">
    <div
        class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-3xl p-1 shadow-2xl shadow-cyan-900/20"
    >
        <div
            id="game-container"
            class="bg-[#0a0a0a] rounded-[22px] overflow-hidden relative group flex flex-col min-h-[460px]"
        >
            <!-- Header -->
            <div
                class="p-4 border-b border-white/5 flex items-center justify-between bg-white/5"
            >
                <div class="flex gap-2 items-center">
                    <button
                        id="close-btn"
                        class="w-3 h-3 rounded-full bg-red-500/50 hover:bg-red-400 flex items-center justify-center text-[8px] text-black font-bold transition-colors cursor-pointer"
                        title="Close"
                    >
                        &times;
                    </button>
                    <button
                        id="minimize-btn"
                        class="w-3 h-3 rounded-full bg-yellow-500/50 hover:bg-yellow-400 flex items-center justify-center text-[8px] text-black font-bold transition-colors cursor-pointer"
                        title="Minimize"
                    >
                        -
                    </button>
                    <button
                        id="fullscreen-btn"
                        class="w-3 h-3 rounded-full bg-green-500/50 hover:bg-green-400 flex items-center justify-center text-[8px] text-black font-bold transition-colors cursor-pointer"
                        title="Fullscreen"
                    >
                        +
                    </button>
                </div>
                <div class="flex items-center gap-2">
                    <select
                        id="game-selector"
                        class="bg-black/20 border border-white/10 rounded px-2 py-1 text-[10px] text-white/60 font-mono focus:outline-none focus:border-cyan-500 hover:bg-white/5 cursor-pointer transition-colors"
                    >
                        <option value="pong" class="bg-gray-900 text-cyan-400"
                            >PONG_V1.CART</option
                        >
                        <option
                            value="breakout"
                            class="bg-gray-900 text-cyan-400"
                            >BLOCK_BREAKER.CART</option
                        >
                        <option value="racing" class="bg-gray-900 text-cyan-400"
                            >NEON_DRIFT_3D.EXE</option
                        >
                    </select>
                </div>
            </div>

            <!-- Game Slots -->
            <div
                id="game-slot-pong"
                class="game-slot w-full flex-1 flex flex-col"
            >
                <Pong />
            </div>
            <div
                id="game-slot-breakout"
                class="game-slot w-full flex-1 flex flex-col hidden"
            >
                <BlockBreaker />
            </div>
            <div
                id="game-slot-racing"
                class="game-slot w-full flex-1 flex flex-col hidden"
            >
                <Racing3D />
            </div>
        </div>
    </div>
</div>

<div
    id="minimized-toast"
    class="mx-auto mt-12 w-fit bg-white/10 backdrop-blur-md border border-white/20 px-6 py-3 rounded-full text-sm font-mono text-cyan-400 pointer-events-auto cursor-pointer hover:bg-white/20 transition-all duration-300 opacity-0 z-50 shadow-lg shadow-cyan-500/20"
>
    Game Minimized // Click Here to Restore
</div>

<script>
    // Fullscreen Toggle Logic
    const fullscreenBtn = document.getElementById("fullscreen-btn");
    const gameContainer = document.getElementById("game-container");

    fullscreenBtn?.addEventListener("click", async () => {
        if (!document.fullscreenElement) {
            try {
                await gameContainer?.requestFullscreen();
            } catch (err: any) {
                console.error(
                    `Error attempting to enable fullscreen mode: ${err.message} (${err.name})`,
                );
            }
        } else {
            if (document.exitFullscreen) {
                document.exitFullscreen();
            }
        }
    });

    // Close Button Logic
    const closeBtn = document.getElementById("close-btn");
    closeBtn?.addEventListener("click", () => {
        if (confirm("Terminate session?")) {
            window.close();
            // Fallback if window.close() is blocked
            window.location.href = "about:blank";
        }
    });

    // Minimize Logic
    const minimizeBtn = document.getElementById("minimize-btn");
    const gamesArea = document.getElementById("games");
    const toast = document.getElementById("minimized-toast");
    let isMinimized = false;

    function toggleMinimize(shouldMinimize: boolean) {
        isMinimized = shouldMinimize;
        if (isMinimized) {
            if (document.fullscreenElement) {
                document.exitFullscreen().catch((err) => console.log(err));
            }
            gamesArea?.classList.add("hidden");
            toast?.classList.remove("opacity-0");
        } else {
            gamesArea?.classList.remove("hidden");
            toast?.classList.add("opacity-0");
        }
    }

    minimizeBtn?.addEventListener("click", () => toggleMinimize(true));

    // Restore: Click on Toast
    toast?.addEventListener("click", () => {
        if (isMinimized) toggleMinimize(false);
    });

    // Game Toggle Logic
    const gameSelector = document.getElementById("game-selector");
    const slots = {
        pong: document.getElementById("game-slot-pong"),
        breakout: document.getElementById("game-slot-breakout"),
        racing: document.getElementById("game-slot-racing"),
    };

    gameSelector?.addEventListener("change", (e: Event) => {
        const selected = (e.target as HTMLSelectElement).value;
        Object.values(slots).forEach((el) => el?.classList.add("hidden"));
        slots[selected as keyof typeof slots]?.classList.remove("hidden");
    });
</script>
<style is:global>
    /* Targets any canvas injected into a game slot to force 
      instant resizing without JS feedback loops 
    */
    .game-slot canvas {
        width: 100% !important;
        height: 100% !important;
        object-fit: contain;
    }
</style>
