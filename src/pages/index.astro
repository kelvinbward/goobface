---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/ui/Navbar.astro";
import SpaceBackground from "../components/ui/SpaceBackground.astro";
import GameIsland from "../components/games/GameIsland.astro";
---

<Layout title="Goobface // Space">
    <div
        class="relative min-h-screen overflow-hidden bg-[#050510] text-white selection:bg-cyan-500 selection:text-black"
    >
        <SpaceBackground />

        <!-- Content Layer (z-index to float above canvas) -->
        <main class="relative z-10 pointer-events-none">
            <Navbar />

            <!-- Hero Section -->
            <section class="max-w-6xl mx-auto px-6 pt-12 pb-24 text-center">
                <div
                    class="inline-block mb-4 px-3 py-1 bg-cyan-500/10 border border-cyan-500/30 rounded-full text-cyan-400 text-xs font-mono tracking-widest pointer-events-auto"
                >
                    SYSTEM STATUS: OPTIMAL
                </div>

                <h1
                    class="text-7xl md:text-9xl font-black mb-6 tracking-tight text-transparent bg-clip-text bg-gradient-to-b from-white to-white/50 animate-fade-in pointer-events-auto"
                >
                    EXPLORE
                    <br />
                    THE VOID
                </h1>

                <p
                    class="text-lg md:text-xl text-blue-200/60 max-w-2xl mx-auto mb-12 leading-relaxed pointer-events-auto"
                >
                    Interactive experiments in digital physics and web
                    entertainment.
                    <br />
                    Click anywhere to ignite the stars.
                </p>

                <GameIsland />
            </section>

            <footer
                class="text-center py-12 text-white/20 text-sm font-mono pointer-events-auto"
            >
                2026 // GOOBFACE LABS
            </footer>
        </main>
    </div>
</Layout>
